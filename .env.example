# --- Commission form (email delivery via Gmail SMTP — free, no domain needed) ---
# The Gmail account that SENDS the notification. Needs an App Password, not
# your regular password: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be turned on for the account first).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Where commission requests are delivered. Can be the same as GMAIL_USER,
# or any other address.
COMMISSION_TO_EMAIL=jack@example.com

# --- Shop ---
# No keys needed — the shop links out to Sticker Mule, which handles its
# own checkout, printing, and shipping.
