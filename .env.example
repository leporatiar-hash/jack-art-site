# --- Commission form (email delivery) ---
# Get a key at https://resend.com  (free tier is fine to start)
RESEND_API_KEY=

# Where commission requests are delivered. Use a verified sender for FROM.
COMMISSION_TO_EMAIL=jack@example.com
COMMISSION_FROM_EMAIL="Commissions <onboarding@resend.dev>"

# --- Shop ---
# No keys needed — the shop links out to Sticker Mule, which handles its
# own checkout, printing, and shipping.
